---
import { Calendar, MapPin } from "@lucide/astro";

interface Props {
  id: string;
  name: string;
  address_1: string;
  address_town: string;
  address_postcode: string;
  dates: { startlocal: string }[];
  price: string;
  description: string;
  image_url: string;
  url: string;
  index: number;
}

const { name, address_1, address_town, dates, image_url, url, index, price } =
  Astro.props;

const isSoldOut = price === "Sold Out";

const isOdd = index % 2 !== 0;
const accent = isOdd ? "247, 147, 204" : "255, 133, 85";

const date = dates?.[0]?.["startlocal"]
  ? new Date(dates[0].startlocal).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const showPrice = !isSoldOut && price && price.trim() !== "";
---

<a
  href={url}
  class="event-card"
  style={`--accent: ${accent};`}
  target="_blank"
  rel="noopener noreferrer"
>
  <div class="card-media">
    <img src={image_url} alt={name} class="card-image" loading="lazy" />
    {isSoldOut && <span class="price-badge sold">Sold Out</span>}
    {showPrice && <span class="price-badge">{price}</span>}
  </div>

  <div class="card-body">
    <h3 class="card-title">{name}</h3>

    <div class="card-meta">
      {
        date && (
          <p class="meta-row">
            <Calendar size={16} aria-hidden="true" />
            <span>{date}</span>
          </p>
        )
      }
      <p class="meta-row">
        <MapPin size={16} aria-hidden="true" />
        <span>{address_1}, {address_town}</span>
      </p>
    </div>

    {
      isSoldOut ? (
        <span class="view-btn sold">Sold Out</span>
      ) : (
        <span class="view-btn">
          View event
          <img src="/outsavvylogo.png" alt="Outsavvy" class="outsavvy-logo" />
        </span>
      )
    }
  </div>
</a>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(46, 31, 35, 0.08);
    box-shadow: 0 4px 16px rgba(46, 31, 35, 0.08);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 32px rgba(46, 31, 35, 0.16);
  }

  .card-media {
    position: relative;
    flex-shrink: 0;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .price-badge {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    background: rgb(255, 89, 94);
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .price-badge.sold {
    background: rgba(46, 31, 35, 0.85);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1.35rem 1.4rem;
    /* accent strip on the left edge of the content */
    border-top: 3px solid rgb(var(--accent));
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.25;
    color: #2e1f23;
    margin: 0;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.95rem;
    color: rgba(46, 31, 35, 0.7);
  }

  .meta-row svg {
    flex-shrink: 0;
    color: rgb(var(--accent));
  }

  .view-btn {
    margin-top: auto;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background-color: rgb(255, 89, 94);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 999px;
    transition:
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .event-card:hover .view-btn:not(.sold) {
    background-color: rgb(235, 70, 75);
    box-shadow: 0 6px 16px rgba(255, 89, 94, 0.35);
  }

  .view-btn.sold {
    background: rgba(46, 31, 35, 0.12);
    color: rgba(46, 31, 35, 0.55);
  }

  .outsavvy-logo {
    height: 1em;
    width: auto;
    vertical-align: middle;
  }

  @media (min-width: 768px) {
    .card-image {
      height: 260px;
    }

    .card-body {
      padding: 1.5rem 1.6rem 1.6rem;
      gap: 0.9rem;
    }

    .card-title {
      font-size: 1.6rem;
    }

    .meta-row {
      font-size: 1.05rem;
    }
  }
</style>
