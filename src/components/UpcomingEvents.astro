---
import EventCard from "./EventCard.astro";

interface Event {
  id: string;
  name: string;
  location_name: string;
  address_1: string;
  address_town: string;
  address_postcode: string;
  dates: { startlocal: string }[];
  price: string;
  description: string;
  image_url: string;
  url: string;
}

const API_URL = "https://api.outsavvy.com/v1/events/search";

let events: Event[] = [];
let fetchFailed = false;
try {
  const res = await fetch(API_URL, {
    headers: {
      "Content-Type": "application/json",
      Authorization: `Partner ${import.meta.env.OUTSAVVY_ACCESS_TOKEN ?? ""}`,
    },
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const json_response = await res.json();
  events = json_response.events;
} catch (err) {
  console.error("Failed to fetch events:", err);
  fetchFailed = true;
}
---

<section>
  {fetchFailed && (
    <p class="events-message">Unable to load events right now. Please check back soon.</p>
  )}
  {!fetchFailed && events.length === 0 && (
    <p class="events-message">No upcoming events at the moment. Check back soon!</p>
  )}
  <div class="events-grid">
    {
      events.map((event, i) => (
        <div class="card-wrapper" style={`--delay: ${i * 0.15}s`}>
          <EventCard {...event} index={i} />
        </div>
      ))
    }
  </div>
</section>

<style>
  .events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin: 1rem;
  }

  @media (min-width: 768px) {
    .events-grid {
      margin: 1rem 2rem;
    }
  }

  .events-message {
    text-align: center;
    padding: 2rem 1rem;
    color: rgba(0, 0, 0, 0.5);
    font-size: 1rem;
  }

  .card-wrapper {
    opacity: 0;
    animation-name: fadeInUp;
    animation-duration: 0.5s;
    animation-timing-function: ease;
    animation-delay: var(--delay, 0s);
    animation-fill-mode: forwards;
  }
</style>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
