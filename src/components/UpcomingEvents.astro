---
import EventCard from "./EventCard.astro";

interface Event {
  id: string;
  name: string;
  location_name: string;
  address_1: string;
  address_town: string;
  address_postcode: string;
  dates: { startlocal: string }[];
  price: string;
  description: string;
  image_url: string;
  url: string;
}

const API_URL = "https://api.outsavvy.com/v1/events/search";

let events: Event[] = [];
let fetchFailed = false;
try {
  console.log(`Partner ${import.meta.env.OUTSAVVY_ACCESS_TOKEN ?? ""}`);
  const res = await fetch(API_URL, {
    headers: {
      "Content-Type": "application/json",
      Authorization: `Partner ${import.meta.env.OUTSAVVY_ACCESS_TOKEN ?? ""}`,
    },
  });
  if (!res.ok)
    throw new Error(
      `HTTP ${res.status} ${res.statusText}: ${await res.text()}`,
    );
  const json_response = await res.json();
  events = json_response.events;
} catch (err) {
  console.error("Failed to fetch events:", err);
  fetchFailed = true;
}
---

<section class="events-section">
  <!-- <h2 class="events-title">Upcoming Events</h2> -->
  {
    fetchFailed && (
      <p class="events-message">
        Unable to load events right now. Please check back soon.
      </p>
    )
  }
  {
    !fetchFailed && events.length === 0 && (
      <p class="events-message">
        No upcoming events at the moment. Check back soon!
      </p>
    )
  }
  <div class="events-grid">
    {
      events.map((event, i) => (
        <div class="card-wrapper" style={`--delay: ${i * 0.15}s`}>
          <EventCard {...event} index={i} />
        </div>
      ))
    }
  </div>
</section>

<style>
  .events-section {
    padding-block: var(--section-space, 3rem);
  }

  .events-title {
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    color: #2e1f23;
    margin: 0 0 1.5rem;
    padding: 0 1rem;
  }

  .events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin: 0 1rem;
  }

  @media (min-width: 768px) {
    .events-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 1024px;
      margin: 0 auto;
      padding: 0 2rem;
    }
  }

  .events-message {
    text-align: center;
    padding: 0 1rem 1.5rem;
    color: rgba(0, 0, 0, 0.5);
    font-size: 1rem;
  }

  .card-wrapper {
    opacity: 0;
    animation-name: fadeInUp;
    animation-duration: 0.5s;
    animation-timing-function: ease;
    animation-delay: var(--delay, 0s);
    animation-fill-mode: forwards;
  }
</style>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
