---
interface Feature {
  title: string;
  body: string;
}

const features: Feature[] = [
  {
    title: "Sober-friendly by design",
    body: "Our events centre connection over the bar. Enjoy a welcoming atmosphere where you never have to drink to belong.",
  },
  {
    title: "For our whole community",
    body: "Events for women (trans inclusive 🏳️‍⚧️) & non-binary people that love women. Everyone deserves a space to feel at home.",
  },
  {
    title: "Glasgow & Edinburgh",
    body: "From socials to nights out, we bring sapphic people together across Glasgow and Edinburgh — with more Scottish cities on the way.",
  },
];
---

<section class="info">
  <div class="info-inner">
    <div class="info-card">
      <div class="info-media">
        <img
          src="/sapphicspaceevent.png"
          alt="Sapphic Space event"
          loading="lazy"
        />
      </div>
      <div class="info-content">
        <h2 class="info-heading">A space made for us</h2>
        <div class="info-features">
          {
            features.map(({ title, body }) => (
              <div class="info-feature">
                <h3 class="info-feature-title">{title}</h3>
                <p class="info-feature-body">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .info {
    padding: var(--section-space, 3rem) 1rem;
  }

  .info-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .info-card {
    display: grid;
    grid-template-columns: 1fr;
    background: #faf2fa;
    border: 1px solid #e0abe0;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(46, 31, 35, 0.06);
  }

  .info-media {
    min-height: 220px;
  }

  .info-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .info-content {
    padding: 2rem 1.75rem;
  }

  .info-heading {
    font-size: 1.9rem;
    font-weight: 800;
    color: #2e1f23;
    margin: 0 0 1.5rem;
  }

  .info-features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-feature-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #2e1f23;
    margin: 0 0 0.35rem;
  }

  .info-feature-body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: rgba(46, 31, 35, 0.7);
  }

  @media (min-width: 768px) {
    .info-card {
      grid-template-columns: 1fr 1.1fr;
    }

    .info-content {
      padding: 2.5rem 2.5rem;
    }
  }
</style>
