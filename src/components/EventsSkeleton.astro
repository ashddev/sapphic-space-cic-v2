---
const cards = Array(2).fill(null);
---

<div class="events-skeleton">
  {cards.map(() => <div class="skeleton-card" />)}
</div>

<style>
  .events-skeleton {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: var(--section-space, 3rem) 1rem;
  }

  @media (min-width: 768px) {
    .events-skeleton {
      grid-template-columns: repeat(2, 1fr);
      max-width: 1024px;
      margin: 0 auto;
      padding: var(--section-space, 3rem) 2rem;
    }
  }

  .skeleton-card {
    height: 420px;
    border-radius: 16px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @media (min-width: 768px) {
    .skeleton-card {
      height: 50dvh;
    }
  }
</style>
