---
import { Mail } from "@lucide/astro";
const items = Array(12).fill(null);
---

<section class="newsletter-section">
  <div
    class="newsletter-marquee"
    aria-label="Be the first to hear about new events"
  >
    <div class="newsletter-track">
      {
        items.map(() => (
          <h2 class="newsletter-heading">
            Be the first to hear about new events
            <Mail class="marquee-icon" size={24} />
          </h2>
        ))
      }
    </div>
  </div>
  <div class="newsletter">
    <form class="newsletter-form" id="newsletter-form">
      <input
        class="email-input"
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        aria-label="Email address"
      />
      <button class="subscribe-btn" type="submit">Subscribe</button>
    </form>
    <p class="newsletter-feedback" id="newsletter-feedback" aria-live="polite">
    </p>
  </div>
</section>

<!-- Newsletter signup handler — uncomment and set the MailerLite env vars to enable.
<script>
  const MAILERLITE_API_KEY = import.meta.env.PUBLIC_MAILERLITE_API_KEY;
  const MAILERLITE_GROUP_ID = import.meta.env.PUBLIC_MAILERLITE_GROUP_ID;

  const form = document.getElementById("newsletter-form") as HTMLFormElement;
  const feedback = document.getElementById("newsletter-feedback")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem("email") as HTMLInputElement).value;

    try {
      const res = await fetch("https://connect.mailerlite.com/api/subscribers", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${MAILERLITE_API_KEY}`,
        },
        body: JSON.stringify({ email, groups: [MAILERLITE_GROUP_ID] }),
      });

      if (res.ok) {
        feedback.textContent = "You're subscribed!";
        form.reset();
      } else {
        feedback.textContent = "Something went wrong. Please try again.";
      }
    } catch {
      feedback.textContent = "Something went wrong. Please try again later.";
    }
  });
</script>
-->

<style>
  .newsletter-section {
    padding: 1rem 0;
    background: #e0abe0;
  }

  .newsletter-marquee {
    overflow: hidden;
    width: 100%;
    margin-bottom: 1rem;
  }

  .newsletter-track {
    display: flex;
    width: max-content;
    animation: newsletter-scroll 30s linear infinite;
  }

  .newsletter-heading {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    white-space: nowrap;
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    padding-right: 1.5rem;
  }

  .marquee-icon {
    color: rgba(255, 255, 255, 0.85);
    flex-shrink: 0;
  }

  @keyframes newsletter-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .newsletter {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .newsletter-form {
    display: flex;
    align-items: center;
    background: #ffffff;
    border: 2.5px solid #1a1a1a;
    border-radius: 50px;
    padding: 6px 6px 6px 20px;
    width: 85%;
    max-width: 480px;
    box-shadow: 3px 4px 0px #1a1a1a; /* the offset dark shadow */
  }

  .email-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1rem;
    color: #ffffff;
    outline: none;
  }

  .email-input::placeholder {
    color: #1a1a1a;
    opacity: 0.6;
  }

  .subscribe-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0; /* hide the word "Subscribe" */
    color: #1a1a1a;
    padding: 6px 12px;
    line-height: 1;
  }

  .subscribe-btn::after {
    content: "→";
    font-size: 1.3rem;
    color: #1a1a1a;
  }

  .newsletter-feedback {
    font-size: 0.9rem;
    color: rgba(46, 31, 35, 0.75);
    margin: 0;
  }
</style>
