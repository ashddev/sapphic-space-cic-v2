---

<section class="newsletter">
  <h2 class="newsletter-heading">Sign up to our mailing list</h2>
  <p class="newsletter-sub">Be the first to hear about new events and announcements.</p>
  <form class="newsletter-form" id="newsletter-form">
    <input
      class="email-input"
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      aria-label="Email address"
    />
    <button class="subscribe-btn" type="submit">Subscribe</button>
  </form>
  <p class="newsletter-feedback" id="newsletter-feedback" aria-live="polite"></p>
</section>

