---
import { MapPin } from "@lucide/astro";

interface Props {
  videoSrc: string;
  outsavvyUrl: string;
  posterSrc?: string;
}

const { videoSrc, outsavvyUrl, posterSrc } = Astro.props;
---

<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline poster={posterSrc}>
    <source src={videoSrc} type="video/mp4" />
  </video>
  <div class="overlay"></div>
  <div class="hero-content">
    <div class="hero-eyebrows">
      <span class="hero-eyebrow">
        <MapPin size={14} aria-hidden="true" />
        Glasgow
      </span>
      <span class="hero-eyebrow">
        <MapPin size={14} aria-hidden="true" />
        Edinburgh
      </span>
    </div>
    <p class="hero-tagline">
      Joyful, sober-friendly events for women (trans inclusive 🏳️‍⚧️) & non-binary
      people that love women.
    </p>
    <a
      href={outsavvyUrl}
      class="cta-button"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>View Events</span>
      <img
        src="/outsavvylogo.png"
        alt="Outsavvy"
        class="outsavvy-logo"
        id="outsavvy-logo"
      />
    </a>
  </div>
</section>

<script>
  const logo = document.getElementById("outsavvy-logo") as HTMLImageElement;
  const content = logo?.closest(".hero-content") as HTMLElement;

  if (logo && content) {
    logo
      .decode()
      .catch(() => {})
      .finally(() => content.classList.add("is-loaded"));
  }
</script>

<style>
  .hero {
    position: relative;
    height: calc(90svh - 2rem);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(38, 35, 38, 0.45),
      rgba(38, 35, 38, 0.65)
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-bottom: none;
    border-radius: 24px 24px 0 0;
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    box-shadow: 0 24px 60px rgba(20, 16, 20, 0.35);
    opacity: 0;
  }

  /* Revealed once the Outsavvy logo has decoded (see script below). */
  .hero-content.is-loaded {
    animation: fadeIn 0.9s ease both;
  }

  .hero-eyebrows {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f6d4f6;
    padding: 0.35rem 0.85rem;
    border: 1px solid rgba(224, 171, 224, 0.6);
    border-radius: 999px;
    background: rgba(224, 171, 224, 0.15);
  }

  .hero-eyebrow svg {
    flex-shrink: 0;
  }

  .hero-tagline {
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
    max-width: 32ch;
    margin: 0;
    text-wrap: balance;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
    padding: 0.9rem 2rem;
    background-color: rgb(255, 89, 94);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 999px;
    box-shadow: 0 8px 20px rgba(255, 89, 94, 0.35);
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cta-button:hover {
    background-color: rgb(235, 70, 75);
    transform: translateY(-2px);
    box-shadow: 0 12px 26px rgba(255, 89, 94, 0.45);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .outsavvy-logo {
    height: 1.1em;
    width: auto;
    vertical-align: middle;
  }

  @media (min-width: 768px) {
    .hero {
      height: calc(92svh - 2rem);
    }

    .hero-content {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1.25rem 1.75rem;
      padding: 1.25rem 2.5rem;
    }

    .hero-tagline {
      text-align: left;
      max-width: 44ch;
      font-size: 1.05rem;
    }

    .cta-button {
      margin-top: 0;
      flex-shrink: 0;
    }
  }
</style>
