---
import { socials } from "../data/socials";
---

<footer>
  <div class="footer-inner">
    <nav class="socials" aria-label="Social media links">
      {
        socials.map(({ label, href, icon }) => (
          <a
            href={href}
            class="social-link"
            aria-label={label}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Fragment set:html={icon} />
          </a>
        ))
      }
    </nav>

    <!-- <a href="/privacy-policy" class="privacy-link">Privacy Policy</a> -->

    <div class="cic-info">
      <p>
        The Sapphic Space is a Community Interest Company (CIC) dedicated to
        creating safe, joyful spaces for sapphic people in Glasgow and
        Edinburgh.
      </p>
      <p class="company-number">
        Company No. 16736619 &mdash; Registered in England &amp; Wales
      </p>
    </div>

    <p class="copyright">
      &copy; {new Date().getFullYear()} The Sapphic Space CIC. All rights reserved.
    </p>
  </div>
</footer>

<style>
  footer {
    background-color: #fff;
    color: rgba(46, 31, 35, 0.85);
    padding: var(--section-space, 3rem) 1.5rem;
    border-top: 1px solid rgba(46, 31, 35, 0.12);
  }

  .footer-inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    text-align: center;
  }

  .socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .social-link {
    color: rgba(46, 31, 35, 0.75);
    display: flex;
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: #2e1f23;
  }

  .privacy-link {
    font-size: 0.85rem;
    color: rgba(46, 31, 35, 0.65);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .privacy-link:hover {
    color: rgba(46, 31, 35, 0.95);
  }

  .cic-info {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    color: rgba(46, 31, 35, 0.65);
    line-height: 1.6;
  }

  .cic-info p:first-child {
    font-weight: 600;
    color: rgba(46, 31, 35, 0.85);
    font-size: 0.9rem;
  }

  .cic-info p {
    margin: 0.4rem;
  }

  .company-number {
    font-size: 0.78rem;
    color: rgba(46, 31, 35, 0.55);
  }

  .copyright {
    font-size: 0.78rem;
    color: rgba(46, 31, 35, 0.5);
  }
</style>
