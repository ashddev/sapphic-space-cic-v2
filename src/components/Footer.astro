---
// TODO: update hrefs with your actual social and policy URLs
const socials = [
  {
    label: "Instagram",
    href: "https://www.instagram.com/thesapphicspaceuk",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    label: "TikTok",
    href: "https://www.tiktok.com/@thesapphicspaceuk",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V9.05a8.16 8.16 0 0 0 4.78 1.52V7.13a4.85 4.85 0 0 1-1.01-.44z"/></svg>`,
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/people/The-Sapphic-Space/61570442771957/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
];
---

<footer>
  <div class="footer-inner">
    <nav class="socials" aria-label="Social media links">
      {
        socials.map(({ label, href, icon }) => (
          <a
            href={href}
            class="social-link"
            aria-label={label}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Fragment set:html={icon} />
          </a>
        ))
      }
    </nav>

    <!-- <a href="/privacy-policy" class="privacy-link">Privacy Policy</a> -->

    <div class="cic-info">
      <p>
        The Sapphic Space is a Community Interest Company (CIC) dedicated to
        creating safe, joyful spaces for sapphic people across the UK.
      </p>
      <p>
        Events for women (trans inclusive 🏳️‍⚧️), &amp; non-binary people that love
        women.
      </p>
      <p class="company-number">
        Company No. 16736619 &mdash; Registered in England &amp; Wales
      </p>
    </div>

    <p class="copyright">
      &copy; {new Date().getFullYear()} The Sapphic Space CIC. All rights reserved.
    </p>
  </div>
</footer>

<style>
  footer {
    background-color: #fff;
    color: rgba(0, 0, 0, 0.8);
    padding: 1.5rem;
  }

  .footer-inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    text-align: center;
  }

  .socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .social-link {
    color: rgba(0, 0, 0, 0.7);
    display: flex;
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: #000;
  }

  .privacy-link {
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.55);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .privacy-link:hover {
    color: rgba(0, 0, 0, 0.9);
  }

  .cic-info {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.5);
    line-height: 1.6;
  }

  .cic-info p:first-child {
    font-weight: 600;
    color: rgba(0, 0, 0, 0.75);
    font-size: 0.9rem;
  }

  .cic-info p {
    margin: 0.4rem;
  }

  .company-number {
    font-size: 0.78rem;
    color: rgba(0, 0, 0, 0.35);
  }

  .copyright {
    font-size: 0.78rem;
    color: rgba(0, 0, 0, 0.3);
  }
</style>
