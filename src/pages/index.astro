---
import Header from "../components/Header.astro";
import VideoHero from "../components/VideoHero.astro";
import UpcomingEvents from "../components/UpcomingEvents.astro";
import EventsSkeleton from "../components/EventsSkeleton.astro";
import MarqueeBanner from "../components/MarqueeBanner.astro";
import InfoSection from "../components/InfoSection.astro";
import Newsletter from "../components/Newsletter.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";

const userAgent = Astro.request.headers.get("user-agent") ?? "";
const isMobile = /Android|iPhone|iPod|Mobile/i.test(userAgent);
const heroVideoSrc = isMobile ? "/hero_mobile.mp4" : "/hero_desktop.mp4";

// --- SEO ---
const siteName = "Sapphic Space UK";
const pageTitle =
  "Sapphic Space UK — Sober-Friendly Sapphic Events in Glasgow & Edinburgh";
const pageDescription =
  "The Sapphic Space — a Community Interest Company creating safe, joyful, sober-friendly events for sapphic people in Glasgow and Edinburgh. Browse upcoming events.";

// Absolute URLs derived from the request so no domain needs hard-coding.
const canonicalUrl = new URL(Astro.url.pathname, Astro.url).href;
const siteOrigin = new URL("/", Astro.url).href;
const ogImage = new URL("/snapshot.jpg", Astro.url).href;
const logoUrl = new URL("/thesapphicspace.png", Astro.url).href;

const socialLinks = [
  "https://www.instagram.com/thesapphicspaceuk",
  "https://www.tiktok.com/@thesapphicspaceuk",
  "https://www.facebook.com/people/The-Sapphic-Space/61570442771957/",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "The Sapphic Space",
  alternateName: siteName,
  url: siteOrigin,
  logo: logoUrl,
  image: ogImage,
  description: pageDescription,
  areaServed: [
    { "@type": "City", name: "Glasgow" },
    { "@type": "City", name: "Edinburgh" },
  ],
  sameAs: socialLinks,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/icon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        /* Standard vertical rhythm between page sections.
           Each section applies this as padding-block, so every
           inter-section gap is a consistent 2 × --section-space. */
        --section-space: 3rem;
      }

      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        background: #fff;
        color: #111;
      }
    </style>
  </head>
  <body>
    <Header logoSrc="/thesapphicspace.png" logoAlt="Sapphic Space UK" />
    <main>
      <VideoHero
        videoSrc={heroVideoSrc}
        outsavvyUrl="https://www.outsavvy.com/organiser/the-sapphic-space-cic"
        posterSrc="/snapshot.jpg"
      />
      <InfoSection />
      <MarqueeBanner text="Upcoming Events" />
      <UpcomingEvents server:defer>
        <EventsSkeleton slot="fallback" />
      </UpcomingEvents>
      <Newsletter />
      <Faq />
    </main>
    <Footer />
  </body>
</html>
